          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/trending",
              "host": ["{{baseUrl}}"],
              "path": ["api", "trending"]
            },
            "description": "### 测试目标\n验证 ZREVRANGE 返回的结果按 heatScore 从高到低排列\n\n### 预期结果\n- data[i].heatScore >= data[i+1].heatScore"
          }
        }
      ]
