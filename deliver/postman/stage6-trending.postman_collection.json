    {
      "name": "5-总分验证 (Score Verification)",
      "description": "综合验证热度分累加规则",
      "item": [
        {
          "name": "T5-1: 综合热度验证",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "var baseline = parseFloat(pm.environment.get('baselineHeatScore') || 0);",
                  "",
                  "var ourArticle = json.data.find(function(item) {",
                  "    return item.id == pm.environment.get('trendingArticleId');",
                  "});",
                  "",
                  "if (ourArticle) {",
                  "    var finalHeat = ourArticle.heatScore;",
                  "    var expectedMin = baseline + 1 + 3 + 2; // 阅读+1 + 点赞+3 + 2次评论×1",
                  "    ",
                  "    console.log('===== 热度分汇总 =====');",
                  "    console.log('基线值:        ' + baseline);",
                  "    console.log('阅读 +1:       ' + (baseline + 1));",
                  "    console.log('点赞 +3:       ' + (baseline + 1 + 3));",
                  "    console.log('评论 +2(×2):   ' + (baseline + 1 + 3 + 2));",
                  "    console.log('实际最终值:     ' + finalHeat);",
                  "    console.log('预期最低值:     ' + expectedMin);",
                  "    console.log('');",
                  "    console.log('TopArticleVO 字段验证:');",
                  "    console.log('  id:        ' + ourArticle.id);",
                  "    console.log('  title:     ' + ourArticle.title);",
                  "    console.log('  authorId:  ' + ourArticle.authorId);",
                  "    console.log('  likeCount: ' + ourArticle.likeCount);",
                  "    console.log('  heatScore: ' + ourArticle.heatScore);",
                  "",
                  "    pm.test('最终热度 >= 基线 + 阅读1 + 点赞3 + 评论2', function() {",
                  "        pm.expect(finalHeat).to.be.at.least(expectedMin);",
                  "    });",
                  "",
                  "    pm.test('heatScore 为有效数值', function() {",
                  "        pm.expect(ourArticle.heatScore).to.be.a('number');",
                  "        pm.expect(ourArticle.heatScore).to.be.above(0);",
                  "    });",
                  "} else {",
                  "    console.log('WARNING: 测试文章未出现在热搜榜中');",
                  "    console.log('可能原因: 文章未发布/Redis ZSET 数据被清空/缓存延迟');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/trending",
              "host": ["{{baseUrl}}"],
              "path": ["api", "trending"]
            },
            "description": "### 测试目标\n汇总验证所有热度来源的累加结果\n\n### 热度分公式\n```\nfinalHeat ≈ baseline + 1(阅读) + 3(点赞) + 2(2次评论)\n         ≈ baseline + 6\n```\n\n### 预期结果\n- 最终热度 >= baseline + 6\n- 所有 TopArticleVO 字段完整有效"
          }
        },
        {
          "name": "T5-2: 榜单降序排列验证",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "var data = json.data;",
