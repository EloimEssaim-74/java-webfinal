                  "if (data.length >= 2) {",
                  "    var sorted = true;",
                  "    for (var i = 1; i < data.length; i++) {",
                  "        if (data[i].heatScore > data[i-1].heatScore) {",
                  "            sorted = false;",
                  "            console.log('排序异常: 第' + i + '位(' + data[i].heatScore + ') > 第' + (i) + '位(' + data[i-1].heatScore + ')');",
                  "        }",
                  "    }",
                  "    pm.test('榜单按热度分降序排列', function() {",
                  "        pm.expect(sorted).to.be.true;",
                  "    });",
                  "} else {",
                  "    console.log('榜单不足2条，跳过排序验证');",
                  "}"
