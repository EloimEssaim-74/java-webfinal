          "request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{tokenA}}"}],"body":{"mode":"raw","raw":"{\"articleId\":{{articleId}},\"content\":\"\"}"},"url":{"raw":"{{baseUrl}}/api/comments","host":["{{baseUrl}}"],"path":["api","comments"]}}
        },
        {
          "name": "D06: Alice点赞",
          "event": [{"listen":"test","script":{"exec":["pm.test('点赞成功',function(){pm.response.to.have.status(200)});","console.log('点赞 heat+3');"],"type":"text/javascript"}}],
          "request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{tokenA}}"}],"url":{"raw":"{{baseUrl}}/api/articles/{{articleId}}/like","host":["{{baseUrl}}"],"path":["api","articles","{{articleId}}","like"]}}
        },
        {
          "name": "D07: 重复点赞→400",
          "event": [{"listen":"test","script":{"exec":["pm.test('HTTP 400',function(){pm.response.to.have.status(400)});","pm.test('已点赞提示',function(){pm.expect(pm.response.json().message).to.include('已点赞');});"],"type":"text/javascript"}}],
          "request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{tokenA}}"}],"url":{"raw":"{{baseUrl}}/api/articles/{{articleId}}/like","host":["{{baseUrl}}"],"path":["api","articles","{{articleId}}","like"]}}
        },
        {
          "name": "D08: 无Token点赞→401",
          "event": [{"listen":"test","script":{"exec":["pm.test('HTTP 401',function(){pm.response.to.have.status(401)});"],"type":"text/javascript"}}],
          "request":{"method":"POST","url":{"raw":"{{baseUrl}}/api/articles/{{articleId}}/like","host":["{{baseUrl}}"],"path":["api","articles","{{articleId}}","like"]}}
